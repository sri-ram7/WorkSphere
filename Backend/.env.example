# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.iyb7wyz.mongodb.net/worksphere

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-separate-refresh-token-secret-change-in-production
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Client URL
CLIENT_URL=https://worksphere-frontend-qrqs.onrender.com

# Email Configuration (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@worksphere.com

# Sentry Error Tracking (optional)
SENTRY_DSN=
